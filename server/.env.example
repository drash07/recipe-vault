# Copy this file to .env in the project root and fill in your real values.
# .env is in .gitignore — it will never be committed.

# Claude API key (from console.anthropic.com → API Keys)
CLAUDE_KEY=sk-ant-api03-...

# Supabase project credentials (from Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# PostHog analytics (from posthog.com → Project Settings → Project API key)
POSTHOG_KEY=phc_...

# Sentry error tracking (from sentry.io → Project → Settings → Client Keys → DSN)
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
